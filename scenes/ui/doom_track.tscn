; Шейдер: только rounded-rect маска (BG).
[sub_resource type="Shader" id="rounded_mask_shader"]
code = "shader_type canvas_item;

uniform vec2 rect_size  = vec2(347.5, 25.0);
uniform float radius_px = 12.0;

void fragment() {
	vec2 p = (UV - 0.5) * rect_size;
	vec2 hsize = rect_size * 0.5;
	vec2 d = abs(p) - hsize + vec2(radius_px);
	float dist = min(max(d.x, d.y), 0.0) + length(max(d, vec2(0.0))) - radius_px;
	if (dist > 0.0) {
		discard;
	}
}
"

[sub_resource type="ShaderMaterial" id="rounded_mask_mat"]
shader = SubResource("rounded_mask_shader")
shader_parameter/rect_size = Vector2(347.5, 25)
shader_parameter/radius_px = 12.0

; Шейдер заливки: rounded-rect маска + плавный фейд правого края до fill_pct.
[sub_resource type="Shader" id="fill_fade_shader"]
code = "shader_type canvas_item;

uniform vec2  rect_size  = vec2(347.5, 25.0);
uniform float radius_px  = 12.0;
uniform float fill_pct   = 0.0;
uniform float fade_width = 0.04;   // ширина фейда в UV (доля от полной длины)

void fragment() {
	// Rounded-rect mask
	vec2 p = (UV - 0.5) * rect_size;
	vec2 hsize = rect_size * 0.5;
	vec2 d = abs(p) - hsize + vec2(radius_px);
	float dist = min(max(d.x, d.y), 0.0) + length(max(d, vec2(0.0))) - radius_px;
	if (dist > 0.0) {
		discard;
	}
	// Правый край заливки: alpha=1 левее (fill_pct - fade_width), плавно до 0 в fill_pct.
	float a = 1.0 - smoothstep(fill_pct - fade_width, fill_pct, UV.x);
	if (a <= 0.001) {
		discard;
	}
	COLOR.a *= a;
}
"

[sub_resource type="ShaderMaterial" id="fill_fade_mat"]
shader = SubResource("fill_fade_shader")
shader_parameter/rect_size = Vector2(347.5, 25)
shader_parameter/radius_px = 12.0
shader_parameter/fill_pct = 0.0
shader_parameter/fade_width = 0.04

