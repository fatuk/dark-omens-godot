; Шейдер круглой маски: discard фрагменты, если их экранная позиция (FRAGCOORD)
; дальше mask_radius_px от mask_center_px. Координаты обновляются скриптом
; и не зависят от вращения узла — маска остаётся неподвижной.
[sub_resource type="Shader" id="circle_mask_shader"]
code = "shader_type canvas_item;

uniform vec2 mask_center_px = vec2(0.0);
uniform float mask_radius_px : hint_range(0.0, 200.0) = 46.0;

void fragment() {
	if (distance(FRAGCOORD.xy, mask_center_px) > mask_radius_px) {
		discard;
	}
}
"

[sub_resource type="ShaderMaterial" id="circle_mask_mat"]
shader = SubResource("circle_mask_shader")
shader_parameter/mask_center_px = Vector2(0, 0)
shader_parameter/mask_radius_px = 46.0

[sub_resource type="CanvasItemMaterial" id="lense_mat"]
blend_mode = 1

[node name="OmensCounter" type="Control"]
custom_minimum_size = Vector2(110, 110)
layout_mode = 3
anchors_preset = 0
mouse_filter = 0
script = ExtResource("1_script")

