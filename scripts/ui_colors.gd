## Дизайн-токены Dark Omens.
## Используй семантические токены (ACCENT, DANGER, …) — не примитивы.
## При смене темы меняй только примитивы — токены подхватят автоматически.
class_name UIColors

# ── Примитивы ──────────────────────────────────────────────────────────────────
# Не используй напрямую в коде сцен/скриптов.

const _VOID    := Color(0.05, 0.04, 0.10)
const _SURFACE := Color(0.08, 0.07, 0.15)
const _COPPER  := Color(0.35, 0.25, 0.10)
const _AMBER   := Color(0.78, 0.66, 0.29)
const _CRIMSON := Color(0.55, 0.10, 0.10)
const _STONE   := Color(0.85, 0.82, 0.75)
const _ASH     := Color(0.55, 0.52, 0.45)
const _SCARLET := Color(0.90, 0.25, 0.20)
const _JADE    := Color(0.30, 0.80, 0.40)
const _TOPAZ   := Color(0.90, 0.75, 0.20)
const _FOREST  := Color(0.20, 0.70, 0.35)

# ── Структура ──────────────────────────────────────────────────────────────────

const BG      := _VOID     ## фон сцены
const SURFACE := _SURFACE  ## фон панелей и карточек
const BORDER  := _COPPER   ## рамки по умолчанию, разделители

# ── Типографика ────────────────────────────────────────────────────────────────

const TEXT  := _STONE  ## основной текст
const MUTED := _ASH    ## второстепенный текст, подсказки, disabled

# ── Роли действий ──────────────────────────────────────────────────────────────

const ACCENT := _AMBER    ## заголовки, основные CTA, иконка хоста
const DANGER := _CRIMSON  ## деструктивные действия (удалить, покинуть)
const SUBTLE := _ASH      ## вторичные / ghost-действия

# ── Семантические состояния ────────────────────────────────────────────────────

const SUCCESS := _JADE    ## подключено, найдено, вход выполнен
const WARNING := _TOPAZ   ## загрузка, ожидание, переподключение
const ERROR   := _SCARLET ## ошибка, потеря соединения

# ── Игровые состояния ─────────────────────────────────────────────────────────

const READY := _FOREST  ## игрок готов, игру можно начинать
