; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="dark-omens"
config/version="0.2.0"
run/main_scene="res://scenes/home.tscn"
config/auto_accept_quit=false
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

NetworkManager="*res://scripts/network/network_manager.gd"
AuthManager="*res://scripts/core/auth_manager.gd"
SceneManager="*res://scripts/core/scene_manager.gd"
GameConsole="*res://scripts/core/game_console.gd"
RelayTransport="*res://scripts/network/relay_transport.gd"
PauseMenu="*res://scenes/ui/pause_menu.tscn"
GameState="*res://scripts/core/game_state.gd"
PostFx="*res://scenes/ui/post_fx.tscn"
PostFxDebug="*res://scenes/ui/post_fx_debug.tscn"
CustomCursor="*res://scenes/ui/custom_cursor.tscn"
ScreenFrame="*res://scripts/ui/screen_frame.gd"
I18n="*res://scripts/core/i18n.gd"
MusicManager="*res://scripts/core/music_manager.gd"
SfxManager="*res://scripts/core/sfx_manager.gd"
SettingsStore="*res://scripts/core/settings_store.gd"
MCPScreenshot="*res://addons/godot_mcp/mcp_screenshot_service.gd"
MCPInputService="*res://addons/godot_mcp/mcp_input_service.gd"
MCPGameInspector="*res://addons/godot_mcp/mcp_game_inspector_service.gd"
ContentApi="*res://scripts/core/content_api.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

movie_writer/movie_file="C:/Users/fatuk/godot_projects/demo.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[gui]

theme/custom_font="res://assets/fonts/Forum-Regular.ttf"

[internationalization]

locale/translations=PackedStringArray("res://assets/i18n/translations.ru.translation", "res://assets/i18n/translations.en.translation")
locale/fallback="ru"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
